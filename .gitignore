node_modules

# 캐시
.cache
.parcel-cache

# IDE
.idea
*.iml
.vscode

# Claude Code 메모리 (로컬 전용)
.claude

# OS
.DS_Store
Thumbs.db

# 환경변수 (추후 백엔드 연동 시)
.env
.env.local
.env.*.local